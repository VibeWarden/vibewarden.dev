<header class="site-header" role="banner">
    <div class="container header-inner">
      <a href="/" class="header-logo" aria-label="VibeWarden home">
        <img src="/static/logo.png" alt="" width="28" height="28" aria-hidden="true">
        <span>VibeWarden</span>
      </a>
      <nav class="header-nav" aria-label="Main navigation">
        {%- for item in nav -%}
        <a href="{{ item.href }}" class="nav-link{%- if navActiveId == item.id %} nav-active{% endif -%}"{% if item.external %} rel="noopener"{% endif %}>{{ item.label }}</a>
        {%- endfor -%}
        <button class="theme-toggle" type="button" aria-label="Toggle dark mode" id="themeToggle">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        {%- if hasMobileNav %}
        <button class="hamburger-btn" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobileNav" id="hamburgerBtn">
          <svg class="icon-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        {%- endif %}
      </nav>
      {%- if hasMobileNav %}
      <div class="mobile-nav" id="mobileNav" role="navigation" aria-label="Mobile navigation">
        {%- for item in nav -%}
        <a href="{{ item.href }}"{% if navActiveId == item.id %} class="nav-active"{% endif %}{% if item.external %} rel="noopener"{% endif %}>{{ item.label }}</a>
        {%- endfor -%}
      </div>
      {%- endif %}
    </div>
  </header>
