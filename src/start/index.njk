---
title: "Start Building — VibeWarden"
description: "Generate a ready-to-paste prompt that sets up VibeWarden as the security sidecar for your vibe-coded app. Runs entirely in your browser."
canonical: "https://vibewarden.dev/start/"
hasMobileNav: true
ogTitle: "Start Building — VibeWarden"
ogDescription: "Generate a ready-to-paste prompt that sets up VibeWarden as the security sidecar for your vibe-coded app."
twitterTitle: "Start Building — VibeWarden"
twitterDescription: "Generate a ready-to-paste prompt that sets up VibeWarden as the security sidecar for your vibe-coded app."
---
{% extends "base.njk" %}


{% block pageStyles %}
  <style>
    /* ===== Page-specific styles ===== */
    .start-section {
      padding: 3rem 0 4rem;
    }

    .start-heading {
      font-size: clamp(1.6rem, 4vw, 2.25rem);
      font-weight: 800;
      text-align: center;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }

    .start-heading .gradient-text {
      background: var(--brand-gradient);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .start-subtitle {
      text-align: center;
      color: var(--text-secondary);
      font-size: 1.05rem;
      margin-bottom: 2.5rem;
    }

    .start-form {
      max-width: 640px;
      margin: 0 auto;
    }

    /* ===== Form fields ===== */
    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      font-weight: 600;
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .form-input,
    .form-textarea {
      width: 100%;
      padding: 0.65rem 0.85rem;
      font-size: 0.95rem;
      font-family: inherit;
      line-height: 1.5;
      color: var(--text-primary);
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-input:focus,
    .form-textarea:focus {
      outline: none;
      border-color: var(--brand-purple);
      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15);
    }

    .form-textarea {
      resize: vertical;
    }


    .field-hint {
      display: block;
      font-size: 0.78rem;
      line-height: 1.4;
      color: var(--text-muted);
      margin-top: 0.3rem;
    }

    /* ===== Feature pills ===== */
    .feature-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .feature-pill {
      position: relative;
    }

    .feature-pill input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .form-group .feature-pill-label {
      display: inline-block;
      padding: 8px 18px;
      font-size: 14px;
      font-weight: 500;
      line-height: 20px;
      border: 1px solid var(--border-color);
      border-radius: 100px;
      cursor: pointer;
      color: var(--text-secondary);
      background: transparent;
      transition: background 0.2s, border-color 0.2s, color 0.2s;
      user-select: none;
      margin-bottom: 0;
    }

    .form-group .feature-pill-label:hover {
      border-color: var(--brand-purple-light);
      color: var(--brand-purple-light);
    }

    .feature-pill input:checked + .feature-pill-label {
      background: var(--brand-purple);
      border-color: var(--brand-purple);
      color: #fff;
    }

    .feature-pill input:focus-visible + .feature-pill-label {
      outline: 2px solid var(--brand-purple);
      outline-offset: 2px;
    }

    /* ===== Generate button ===== */
    .generate-row {
      margin-top: 2rem;
      text-align: center;
    }

    .generate-row .btn {
      min-width: 180px;
    }

    /* ===== Output ===== */
    .output-area {
      max-width: 640px;
      margin: 0 auto;
      display: none;
    }

    .output-area.visible {
      display: block;
    }

    .output-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.5rem;
    }

    .output-label {
      font-weight: 600;
      font-size: 0.95rem;
    }

    .copy-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.4rem 0.85rem;
      font-size: 0.825rem;
      font-weight: 500;
      font-family: inherit;
      background: var(--bg-card);
      color: var(--text-secondary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }

    .features-note {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    /* Auth expandable pill */
    .auth-pill-wrap {
      position: relative;
      display: inline-flex;
    }

    .auth-pill-wrap.expanded .auth-collapsed {
      display: none;
    }

    .auth-expanded {
      display: none;
      align-items: stretch;
      border: 1px solid var(--brand-purple);
      border-radius: 100px;
      background: rgba(124, 58, 237, 0.06);
      animation: authExpand 0.25s ease;
      overflow: visible;
    }

    .auth-pill-wrap.expanded .auth-expanded {
      display: inline-flex;
    }

    @keyframes authExpand {
      from { opacity: 0; transform: scaleX(0.6); }
      to { opacity: 1; transform: scaleX(1); }
    }

    .auth-opt {
      position: relative;
      flex: 1 1 0;
      min-width: 0;
    }

    .auth-opt input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .form-group .auth-opt label {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px 18px;
      font-size: 14px;
      font-weight: 500;
      line-height: 20px;
      cursor: pointer;
      color: var(--text-secondary);
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
      position: relative;
      margin-bottom: 0;
    }

    .auth-opt:first-child label {
      border-radius: 100px 0 0 100px;
    }

    .auth-opt:last-of-type label {
      border-radius: 0;
    }

    .auth-opt label:hover {
      color: var(--brand-purple);
    }

    .auth-opt input:checked + label {
      color: #fff;
      background: var(--brand-purple);
    }

    .auth-opt input:focus-visible + label {
      outline: 2px solid var(--brand-purple);
      outline-offset: -2px;
    }

    .auth-close-btn {
      background: none;
      border: none;
      border-left: 1px solid var(--border-color);
      padding: 8px 10px;
      cursor: pointer;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      border-radius: 0 100px 100px 0;
      transition: color 0.15s;
    }

    .auth-close-btn:hover {
      color: var(--brand-purple);
    }

    .auth-close-btn svg {
      width: 14px;
      height: 14px;
    }

    /* Tooltips */

    /* HTML tooltips */
    .has-tooltip {
      position: relative;
    }

    .tooltip {
      display: none;
      position: absolute;
      bottom: calc(100% + 12px);
      left: 50%;
      transform: translateX(-50%);
      width: 380px;
      padding: 0;
      background: #1a1a2e;
      border-radius: 10px;
      z-index: 100;
      pointer-events: none;
      box-shadow: 0 8px 24px rgba(0,0,0,0.35);
      overflow: visible;
      text-align: left;
    }

    /* Prevent tooltip from going off-screen on right */
    .auth-opt:last-of-type .tooltip {
      left: auto;
      right: -20px;
      transform: none;
    }
    .auth-opt:last-of-type .tooltip::after {
      left: auto;
      right: 40px;
      transform: none;
    }

    .has-tooltip:hover .tooltip {
      display: block;
    }

    .tooltip::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 7px solid transparent;
      border-top-color: #1a1a2e;
    }

    .tooltip * {
      white-space: normal;
    }

    .tooltip-title {
      display: block;
      padding: 10px 14px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #a78bfa;
      background: rgba(124, 58, 237, 0.15);
      border-radius: 10px 10px 0 0;
    }

    .tooltip-what {
      display: block;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 400;
      line-height: 1.55;
      color: #e0e0e0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .tooltip-when {
      display: block;
      padding: 10px 14px;
      font-size: 12px;
      font-weight: 400;
      line-height: 1.5;
      color: #8888a8;
    }

    .tooltip-when::before {
      content: "When to use: ";
      font-weight: 600;
      color: #a0a0c0;
    }

    /* Privacy note below form */
    .privacy-note {
      text-align: center;
      color: var(--text-muted);
      font-size: 0.8rem;
      margin-top: 1.5rem;
    }

    .privacy-note svg {
      width: 14px;
      height: 14px;
      vertical-align: -2px;
      margin-right: 0.25rem;
    }

    @media (prefers-reduced-motion: reduce) {
      .auth-expanded { animation: none; }
    }

    .copy-btn:hover {
      border-color: var(--brand-purple);
      color: var(--brand-purple);
    }

    .copy-btn:focus-visible {
      outline: 2px solid var(--brand-purple);
      outline-offset: 2px;
    }

    .copy-btn svg {
      width: 14px;
      height: 14px;
    }

    .copy-btn .icon-check {
      display: none;
      color: #22c55e;
    }

    .copy-btn.copied .icon-clipboard { display: none; }
    .copy-btn.copied .icon-check { display: inline-block; }
    .copy-btn.copied { border-color: #22c55e; color: #22c55e; }

    .output-textarea {
      width: 100%;
      padding: 1rem;
      font-family: ui-monospace, "SFMono-Regular", "SF Mono", Menlo, Consolas, monospace;
      font-size: 0.85rem;
      line-height: 1.6;
      color: var(--text-code);
      background: var(--bg-code);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      resize: vertical;
    }

    .output-textarea:focus {
      outline: none;
      border-color: var(--brand-purple);
      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15);
    }

    .output-note {
      text-align: center;
      color: var(--text-muted);
      font-size: 0.8rem;
      margin-top: 1rem;
    }


    /* ===== Mobile ===== */
    @media (max-width: 480px) {
      .start-section {
        padding: 2rem 0 3rem;
      }

      .form-group .feature-pill-label {
        font-size: 0.8rem;
        padding: 0.4rem 0.85rem;
      }
    }
  </style>
{% endblock %}

{% block content %}
    <section class="start-section" aria-labelledby="start-heading">
      <div class="container">
        <h1 id="start-heading" class="start-heading"><span class="gradient-text">Start Building</span></h1>
        <p class="start-subtitle">Generate a prompt to bootstrap your app with VibeWarden.</p>

        <form class="start-form" id="startForm" aria-label="Prompt generator">

          <!-- What are you building? -->
          <div class="form-group">
            <label for="whatField">What are you building?</label>
            <textarea class="form-textarea" id="whatField" name="what" rows="3" required placeholder="A QR code generator web app" aria-required="true"></textarea>
          </div>

          <!-- Deploy target -->
          <div class="form-group">
            <label for="deployTarget">Domain or server IP</label>
            <input class="form-input" type="text" id="deployTarget" name="deployTarget" placeholder="myapp.example.com or 203.0.113.42">
            <small class="field-hint">Optional. Leave empty to run locally only.</small>
          </div>

          <!-- Features -->
          <div class="form-group">
            <label id="featuresLabel">Features</label>
            <p class="features-note">TLS, security headers, and rate limiting are enabled by default. Select additional features:</p>
            <div class="feature-pills" role="group" aria-labelledby="featuresLabel">
              <!-- Auth: expandable pill -->
              <span class="auth-pill-wrap" id="authPill">
                <input type="hidden" id="featAuth" name="features" value="auth" disabled>
                <label class="feature-pill-label auth-collapsed has-tooltip" id="authTrigger">Login &amp; Signup
                  <span class="tooltip">
                    <span class="tooltip-title">Authentication</span>
                    <span class="tooltip-what">Add user login, signup, or API key validation to your app.</span>
                    <span class="tooltip-when">Pick this if your app has users or protected endpoints.</span>
                  </span>
                </label>
                <span class="auth-expanded">
                  <span class="auth-opt">
                    <input type="radio" id="authJwt" name="authType" value="jwt" checked>
                    <label for="authJwt" class="has-tooltip">External provider
                      <span class="tooltip">
                        <span class="tooltip-title">JWT / OIDC</span>
                        <span class="tooltip-what">Validate tokens from Auth0, Cognito, Clerk, Firebase, or any OIDC provider.</span>
                        <span class="tooltip-when">Choose this if you already have an auth provider.</span>
                      </span>
                    </label>
                  </span>
                  <span class="auth-opt">
                    <input type="radio" id="authKratos" name="authType" value="kratos">
                    <label for="authKratos" class="has-tooltip">Built-in accounts
                      <span class="tooltip">
                        <span class="tooltip-title">Ory Kratos</span>
                        <span class="tooltip-what">Full built-in user management with signup, login, and password reset.</span>
                        <span class="tooltip-when">Choose this if you don't have an auth provider yet.</span>
                      </span>
                    </label>
                  </span>
                  <button type="button" class="auth-close-btn" id="authCloseBtn" aria-label="Disable authentication">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </span>
              </span>
              <span class="feature-pill">
                <input type="checkbox" id="featWaf" name="features" value="waf">
                <label class="feature-pill-label has-tooltip" for="featWaf">Attack protection
                  <span class="tooltip">
                    <span class="tooltip-title">WAF (Web Application Firewall)</span>
                    <span class="tooltip-what">Blocks SQL injection, XSS, path traversal, and command injection attacks.</span>
                    <span class="tooltip-when">Pick this if your app has forms, search, or any user input.</span>
                  </span>
                </label>
              </span>
              <span class="feature-pill">
                <input type="checkbox" id="featPrompt" name="features" value="prompt">
                <label class="feature-pill-label has-tooltip" for="featPrompt">AI safety
                  <span class="tooltip">
                    <span class="tooltip-title">Prompt injection detection</span>
                    <span class="tooltip-what">Inspects outbound requests to LLMs for prompt injection patterns.</span>
                    <span class="tooltip-when">Pick this if your app calls OpenAI, Anthropic, or any AI API.</span>
                  </span>
                </label>
              </span>
              <span class="feature-pill">
                <input type="checkbox" id="featWebhook" name="features" value="webhook">
                <label class="feature-pill-label has-tooltip" for="featWebhook">Webhook verification
                  <span class="tooltip">
                    <span class="tooltip-title">Webhook signature verification</span>
                    <span class="tooltip-what">Validates incoming webhook signatures to prevent spoofing.</span>
                    <span class="tooltip-when">Pick this if you receive webhooks from Stripe, GitHub, Slack, or Twilio.</span>
                  </span>
                </label>
              </span>
              <span class="feature-pill">
                <input type="checkbox" id="featSecrets" name="features" value="secrets">
                <label class="feature-pill-label has-tooltip" for="featSecrets">Secret vault
                  <span class="tooltip">
                    <span class="tooltip-title">OpenBao secret management</span>
                    <span class="tooltip-what">Injects API keys, database credentials, and rotates secrets automatically.</span>
                    <span class="tooltip-when">Pick this if your app connects to databases or third-party APIs with sensitive keys.</span>
                  </span>
                </label>
              </span>
              <span class="feature-pill">
                <input type="checkbox" id="featIpFilter" name="features" value="ipfilter">
                <label class="feature-pill-label has-tooltip" for="featIpFilter">IP allowlist / blocklist
                  <span class="tooltip">
                    <span class="tooltip-title">IP filtering</span>
                    <span class="tooltip-what">Allow or block traffic by IP address or CIDR range.</span>
                    <span class="tooltip-when">Pick this if you need to restrict access to specific networks or block known bad actors.</span>
                  </span>
                </label>
              </span>
            </div>
          </div>

          <!-- Generate -->
          <div class="generate-row">
            <button type="submit" class="btn btn-primary">Generate</button>
          </div>

          <p class="privacy-note">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Nothing is sent to any server. This runs entirely in your browser.
          </p>
        </form>

        <!-- Output -->
        <div class="output-area" id="outputArea" aria-live="polite">
          <div style="height: 2rem;"></div>
          <div class="output-header">
            <span class="output-label">Paste this to your agent</span>
            <button type="button" class="copy-btn" id="copyBtn" aria-label="Copy prompt to clipboard">
              <svg class="icon-clipboard" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span class="copy-btn-text">Copy</span>
            </button>
          </div>
          <textarea class="output-textarea" id="outputText" rows="8" readonly aria-label="Generated prompt"></textarea>
          <p class="output-note">Nothing is sent to any server. This runs entirely in your browser.</p>
        </div>

      </div>
    </section>
{% endblock %}

{% block pageScripts %}
<script>
  // Auth expandable pill
  (function() {
    var wrap = document.getElementById('authPill');
    var trigger = document.getElementById('authTrigger');
    var closeBtn = document.getElementById('authCloseBtn');
    var hiddenInput = document.getElementById('featAuth');
    if (!wrap || !trigger || !closeBtn || !hiddenInput) return;

    trigger.addEventListener('click', function() {
      wrap.classList.add('expanded');
      hiddenInput.disabled = false;
    });

    closeBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      wrap.classList.remove('expanded');
      hiddenInput.disabled = true;
    });
  })();

  // Prompt generation
  (function() {
    var form = document.getElementById('startForm');
    var outputArea = document.getElementById('outputArea');
    var outputText = document.getElementById('outputText');
    var copyBtn = document.getElementById('copyBtn');
    if (!form || !outputArea || !outputText) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var what = document.getElementById('whatField').value.trim();
      if (!what) return;

      // Build vibew init command with flags
      var initFlags = [];
      var authInput = document.getElementById('featAuth');
      var authEnabled = authInput && !authInput.disabled;
      if (authEnabled) {
        initFlags.push('--auth');
      }

      // Deploy target
      var deployTarget = (document.getElementById('deployTarget').value || '').trim();
      var isDomain = deployTarget && !/^\d+\.\d+\.\d+\.\d+$/.test(deployTarget);

      if (isDomain) {
        initFlags.push('--tls --domain ' + deployTarget);
      }

      var initCmd = 'vibew init' + (initFlags.length > 0 ? ' ' + initFlags.join(' ') : '');

      // Base prompt with the constructed init command
      var prompt = 'Build ' + what + ' with VibeWarden as the security sidecar.\n\nVibeWarden is open source (Apache 2.0).\n  GitHub: https://github.com/vibewarden/vibewarden\n  Docs:   https://vibewarden.dev/llms-full.txt\n\nInstall: curl -fsSL https://vibewarden.dev/install.sh | sh';
      prompt += '\n\nRun: `' + initCmd + '`';
      prompt += '\nThen build the app on top of the scaffolded project.';

      // Auth type detail
      if (authEnabled) {
        var checked = document.querySelector('input[name="authType"]:checked');
        var authType = checked ? checked.value : 'jwt';
        if (authType === 'kratos') {
          prompt += ' Authentication is set to built-in signup/login (Ory Kratos, `auth.mode: kratos`).';
        } else {
          prompt += ' Configure JWT authentication in `vibewarden.yaml` (`auth.mode: jwt` with your JWKS URL).';
        }
      }

      // YAML-only features
      var yamlFeatures = [];
      var featureBoxes = form.querySelectorAll('input[name="features"][type="checkbox"]:checked');
      for (var i = 0; i < featureBoxes.length; i++) {
        var key = featureBoxes[i].value;
        switch (key) {
          case 'waf': yamlFeatures.push('WAF protection (`waf.enabled: true`)'); break;
          case 'prompt': yamlFeatures.push('prompt injection detection on egress routes'); break;
          case 'webhook': yamlFeatures.push('webhook signature verification'); break;
          case 'secrets': yamlFeatures.push('secret management with OpenBao (`secrets.enabled: true`)'); break;
          case 'ipfilter': yamlFeatures.push('IP filtering (`ip_filter.enabled: true`)'); break;
        }
      }
      if (yamlFeatures.length > 0) {
        prompt += '\n\nAlso enable in `vibewarden.yaml`: ' + yamlFeatures.join(', ') + '.';
      }

      // Deploy
      if (deployTarget) {
        if (isDomain) {
          prompt += '\n\nDeploy to `' + deployTarget + '` using `vibew deploy`. Docker is installed on the server and DNS is configured.';
        } else {
          prompt += '\n\nDeploy to server `' + deployTarget + '` using `vibew deploy`. Docker is installed.';
        }
      } else {
        prompt += '\n\nWhen the app is ready, deploy using `vibew deploy`.';
      }

      outputText.value = prompt;
      outputArea.classList.add('visible');
      outputText.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    // Copy button
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var text = outputText.value;
        if (!text) return;

        if (navigator.clipboard) {
          navigator.clipboard.writeText(text).then(function() {
            showCopied();
          });
        } else {
          // Fallback
          outputText.select();
          document.execCommand('copy');
          showCopied();
        }
      });
    }

    var copyTimeout;
    function showCopied() {
      copyBtn.classList.add('copied');
      var textEl = copyBtn.querySelector('.copy-btn-text');
      if (textEl) textEl.textContent = 'Copied';
      clearTimeout(copyTimeout);
      copyTimeout = setTimeout(function() {
        copyBtn.classList.remove('copied');
        if (textEl) textEl.textContent = 'Copy';
      }, 2000);
    }
  })();
</script>
{% endblock %}
