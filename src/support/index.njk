---
title: "Support — VibeWarden"
description: "Get help with VibeWarden. Community support via GitHub, documentation, security reporting, and upcoming pro support options."
canonical: "https://vibewarden.dev/support/"
navActiveId: support
hasMobileNav: false
ogType: website
ogTitle: "Support — VibeWarden"
ogDescription: "Get help with VibeWarden. Community support, security reporting, and pro support options."
---
{% extends "base.njk" %}


{% block pageStyles %}
<style>
    /* ===== Support Cards ===== */
    .support-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
    }

    .support-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.75rem;
      transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
      box-shadow: var(--card-shadow);
      display: flex;
      flex-direction: column;
    }

    .support-card:hover {
      box-shadow: var(--card-shadow-hover);
      border-color: var(--brand-purple);
      transform: translateY(-2px);
    }

    .support-card-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: var(--brand-gradient);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      flex-shrink: 0;
    }

    .support-card-icon svg { width: 22px; height: 22px; color: #FFFFFF; }

    .support-card h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .support-card p {
      font-size: 0.9rem;
      color: var(--text-secondary);
      line-height: 1.55;
      margin-bottom: 1rem;
      flex-grow: 1;
    }

    .support-card .card-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--brand-purple-light);
    }

    .support-card .card-link:hover { text-decoration: underline; }

    .support-card .card-link svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    /* ===== Security Section ===== */
    .security-section {
      background: var(--bg-secondary);
    }

    .security-box {
      background: var(--bg-card);
      border: 2px solid var(--brand-purple);
      border-radius: 12px;
      padding: 2rem;
      max-width: 680px;
      margin: 0 auto;
      box-shadow: var(--card-shadow);
    }

    .security-box-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .security-box-header .icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: var(--brand-gradient);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .security-box-header .icon svg { width: 22px; height: 22px; color: #FFFFFF; }

    .security-box-header h3 {
      font-size: 1.15rem;
      font-weight: 700;
    }

    .security-box p {
      font-size: 0.95rem;
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 0.75rem;
    }

    .security-box .email-link {
      font-weight: 600;
      color: var(--brand-purple-light);
    }

    .security-box .warning {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-style: italic;
      margin-top: 0.5rem;
      margin-bottom: 0;
    }

    /* ===== Pro Support ===== */
    .pro-section {
      padding: 4rem 0;
    }

    .pro-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      max-width: 680px;
      margin: 0 auto;
      box-shadow: var(--card-shadow);
      position: relative;
    }

    .pro-card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
    }

    .pro-card-header h3 {
      font-size: 1.15rem;
      font-weight: 700;
    }

    .badge-coming-soon {
      display: inline-block;
      background: var(--brand-gradient);
      color: #FFFFFF;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 0.25rem 0.65rem;
      border-radius: 20px;
    }

    .pro-features {
      list-style: none;
      padding: 0;
      margin-bottom: 1.5rem;
    }

    .pro-features li {
      font-size: 0.95rem;
      color: var(--text-secondary);
      padding: 0.4rem 0;
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
    }

    .pro-features li svg {
      width: 18px;
      height: 18px;
      color: var(--brand-cyan);
      flex-shrink: 0;
      margin-top: 0.1rem;
    }

    .pro-card p.pro-note {
      font-size: 0.9rem;
      color: var(--text-muted);
    }

    /* ===== Contact Section ===== */
    .contact-section {
      background: var(--bg-secondary);
      text-align: center;
      padding: 4rem 0;
    }

    .contact-section h2 {
      font-size: clamp(1.5rem, 3.5vw, 2rem);
      font-weight: 700;
      margin-bottom: 0.75rem;
    }

    .contact-section p {
      color: var(--text-secondary);
      font-size: 1.05rem;
      max-width: 480px;
      margin: 0 auto 1.5rem;
    }

    /* ===== Responsive ===== */
    @media (max-width: 480px) {
      section { padding: 3rem 0; }
      .page-hero { padding: 3rem 0 2rem; }
      .security-box { padding: 1.5rem; }
      .pro-card { padding: 1.5rem; }
    }

    @media (min-width: 768px) {
      .support-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
{% endblock %}

{% block content %}
    <!-- Page Hero -->
    <section class="page-hero" aria-labelledby="page-heading">
      <div class="container">
        <h1 id="page-heading"><span class="gradient-text">Support</span></h1>
        <p>Get help, report issues, or reach the team. The VibeWarden community is here for you.</p>
      </div>
    </section>

    <!-- Community Support -->
    <section class="community-section" aria-labelledby="community-heading">
      <div class="container">
        <div class="section-header">
          <h2 id="community-heading">Community support</h2>
          <p>Free, open, and powered by the community.</p>
        </div>
        <div class="support-grid" role="list">
          <article class="support-card" role="listitem">
            <div class="support-card-icon" aria-hidden="true">
              <!-- Bug / Issues icon -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <h3>GitHub Issues</h3>
            <p>Found a bug or have a feature request? Open an issue on GitHub. We triage actively.</p>
            <a href="https://github.com/vibewarden/vibewarden/issues" class="card-link" rel="noopener">
              Open an issue
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          </article>
          <article class="support-card" role="listitem">
            <div class="support-card-icon" aria-hidden="true">
              <!-- Discussions icon -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3>GitHub Discussions</h3>
            <p>Ask questions, share your setup, and connect with other VibeWarden users.</p>
            <a href="https://github.com/vibewarden/vibewarden/discussions" class="card-link" rel="noopener">
              Join the discussion
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          </article>
          <article class="support-card" role="listitem">
            <div class="support-card-icon" aria-hidden="true">
              <!-- Docs icon -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h3>Documentation</h3>
            <p>Guides, configuration reference, and examples. Most questions are answered here.</p>
            <a href="/docs/vibewarden/" class="card-link">
              Read the docs
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>
          <article class="support-card" role="listitem">
            <div class="support-card-icon" aria-hidden="true">
              <!-- Wrench / Troubleshooting icon -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h3>Troubleshooting</h3>
            <p>Common issues and their solutions. Check here before opening an issue.</p>
            <a href="/docs/vibewarden/troubleshooting/" class="card-link">
              Troubleshooting guide
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- Security Reporting -->
    <section class="security-section" aria-labelledby="security-heading">
      <div class="container">
        <div class="section-header">
          <h2 id="security-heading">Security reporting</h2>
          <p>Responsible disclosure keeps everyone safe.</p>
        </div>
        <div class="security-box">
          <div class="security-box-header">
            <div class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Report a vulnerability</h3>
          </div>
          <p>If you discover a security vulnerability in VibeWarden, please report it responsibly. Send details to <a href="mailto:security@vibewarden.dev" class="email-link">security@vibewarden.dev</a>. We will acknowledge your report within 48 hours and work with you to resolve the issue.</p>
          <p class="warning">Please do not open public GitHub issues for security vulnerabilities. Use the email above for responsible disclosure.</p>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="contact-section" aria-labelledby="contact-heading">
      <div class="container">
        <h2 id="contact-heading">General inquiries</h2>
        <p>Have a question that does not fit the categories above? We would love to hear from you.</p>
        <a href="mailto:hello@vibewarden.dev" class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          hello@vibewarden.dev
        </a>
      </div>
    </section>
{% endblock %}
